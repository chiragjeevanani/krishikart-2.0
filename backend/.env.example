MONGO_URI=mongodb://localhost:27017/kisaankart
APP_NAME=Kisaankart
PORT=3000
HOSTNAME=0.0.0.0

# JWT configuration
JWT_SECRET=change-me-to-a-strong-secret
JWT_EXPIRES_IN=7d

# Firebase Admin - choose ONE of the following:

# Option 1: Inline JSON (recommended for platforms that support secure env injection)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id", ...}

# Option 2: Path to service account JSON file (use with backend/app/services/firebaseAdmin.js)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Optional: staging/dev — if true, DEFAULT_OTP is accepted for any valid mobile (user, franchise, delivery login; user/delivery/vendor password reset). USE_DEFAULT_OTP is an alias for the typo USE_DEFALT_OTP.
# USE_DEFALT_OTP=false
# DEFAULT_OTP=

# Google Maps API Key (for geocoding and location services)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

